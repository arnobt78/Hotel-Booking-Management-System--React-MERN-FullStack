# ================================================
# Hotel Booking Backend - Environment Variables
# ================================================
# Copy this file to .env and fill in your values

# ================================================
# SERVER CONFIGURATION
# ================================================
# Canonical local port (must match frontend VITE_API_BASE_URL and Google OAuth redirect URI)
PORT=5001

# Node environment (development, production, test)
NODE_ENV=development

# ================================================
# DATABASE CONFIGURATION
# ================================================
# MongoDB connection string (MongoDB Atlas or local)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_CONNECTION_STRING=your_mongodb_connection_string_here

# ================================================
# AUTHENTICATION & SECURITY
# ================================================
# JWT Secret Key (use a strong, random string)
# Generate with: openssl rand -base64 512
JWT_SECRET_KEY=your_jwt_secret_key_here

# ================================================
# FRONTEND & BACKEND CONFIGURATION
# ================================================
# Frontend URL for CORS (your React app URL)
# Local development: http://localhost:5174
# Production: https://hotel-mern-booking.vercel.app
FRONTEND_URL=http://localhost:5174

# Backend public URL (OAuth redirect_uri = {BACKEND_URL}/api/auth/callback/google)
# Local: leave unset (uses http://localhost:PORT). Add same URI in Google Console if using Google sign-in.
# Production: https://hotel-booking-backend.duckdns.org
# BACKEND_URL=https://hotel-booking-backend.duckdns.org

# Google OAuth — register redirect URI in Google Cloud Console (see auth.ts BACKEND_URL)
GOOGLE_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_SECRET=your_google_client_secret

# ================================================
# CLOUDINARY CONFIGURATION
# ================================================
# Cloudinary credentials for image storage
# Sign up at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ================================================
# STRIPE PAYMENT CONFIGURATION
# ================================================
# Stripe API key for payment processing
# Get from: https://dashboard.stripe.com/apikeys
# Use test key for development: sk_test_...
# Use live key for production: sk_live_...
STRIPE_API_KEY=your_stripe_secret_key_here

# ================================================
# OPTIONAL CONFIGURATION
# ================================================
# Add any additional environment variables below
