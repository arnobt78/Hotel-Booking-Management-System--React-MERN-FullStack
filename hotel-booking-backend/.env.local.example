# Copy to .env.local (gitignored). Keep PORT aligned with frontend VITE_API_BASE_URL.
# 5001 avoids macOS AirPlay on 5000 (Control Center). Match frontend VITE_API_BASE_URL.
PORT=5001
FRONTEND_URL=http://localhost:5174
