# Copy to .env.local (gitignored). Must match backend PORT (default 5001; 5000 often taken on macOS).
VITE_API_BASE_URL=http://localhost:5001

# Stripe publishable key (pk_test_...) — required for Booking page payments (AppContext).
# Backend STRIPE_API_KEY (secret) creates PaymentIntents and processes refunds on cancel.
# VITE_STRIPE_PUB_KEY=pk_test_your_publishable_key
